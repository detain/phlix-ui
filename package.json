{
    "name": "@phlix/ui",
    "version": "0.7.0",
    "description": "Shared Vue 3 UI components and utilities for Phlix",
    "type": "module",
    "main": "./dist/phlix-ui.umd.cjs",
    "module": "./dist/phlix-ui.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/phlix-ui.js",
            "require": "./dist/phlix-ui.umd.cjs",
            "types": "./dist/index.d.ts"
        },
        "./style.css": "./dist/style.css",
        "./fonts.css": "./dist/fonts/fonts.css",
        "./dist/*": "./dist/*"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json && node scripts/copy-fonts.mjs",
        "preview": "vite preview",
        "test": "vitest",
        "test:run": "vitest run",
        "lint": "eslint . --ext .ts,.vue --fix",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "pinia": "^2.1.0",
        "vue": "^3.4.0",
        "vue-router": "^4.3.0"
    },
    "devDependencies": {
        "@iconify-json/lucide": "^1.2.111",
        "@types/node": "^20.11.30",
        "@vitejs/plugin-vue": "^5.0.4",
        "@vue/test-utils": "^2.4.10",
        "@vue/tsconfig": "^0.5.1",
        "jsdom": "^29.1.1",
        "typescript": "^5.4.3",
        "unplugin-icons": "^23.0.1",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vue-tsc": "^2.0.7"
    },
    "peerDependencies": {
        "pinia": "^2.1.0",
        "vue": "^3.4.0",
        "vue-router": "^4.3.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "github:detain/phlix-ui"
    },
    "keywords": [
        "phlix",
        "vue",
        "ui",
        "components"
    ],
    "license": "MIT"
}
